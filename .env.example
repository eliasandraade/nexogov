# NexoGov — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# Never commit .env or .env.local to git.

# ─── Database (Railway PostgreSQL) ───────────────────────────────────────────
# Provided automatically by Railway when the PostgreSQL plugin is attached.
# For local development, use the public URL from:
#   Railway Dashboard → PostgreSQL → Connect → Public URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/railway"

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Base URL of the application (used by Auth.js for callbacks and redirects).
# Development: http://localhost:3000
# Production:  https://<your-app>.up.railway.app
AUTH_URL="http://localhost:3000"

# ─── Cloudinary (document storage) ───────────────────────────────────────────
# Available at: https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Cron job protection ─────────────────────────────────────────────────────
# Sent as Bearer token in the Authorization header by the scheduler.
# Generate with: openssl rand -hex 32
CRON_SECRET=""
